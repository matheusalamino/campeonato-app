# Credenciais do banco remoto de producao.
# Copie para .secrets/production.env e preencha com os valores reais.

REMOTE_DB_HOST=aws-0-us-east-1.pooler.supabase.com
REMOTE_DB_PORT=5432
REMOTE_DB_NAME=postgres
REMOTE_DB_USER=postgres.SEUPROJETO
REMOTE_DB_PASSWORD=replace-me

# Para Supabase remoto, normalmente use SSL.
REMOTE_DB_SSLMODE=require
